# App
NEXT_PUBLIC_APP_NAME=WebProvisionning
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# URL publique du déploiement (obligatoire en prod pour P237 / liens dans les configs)
# Ex. https://webprovisionning-production.up.railway.app
APP_URL=
NEXT_PUBLIC_APP_URL=

# Grandstream : 1 = HTTP/HTTPS via URL (défaut, max compat). Surcharger si besoin : 0=TFTP, 2=HTTPS explicite
# GRANDSTREAM_P212_UPGRADE_VIA=1

# Database (Prisma/PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webprovisionning?schema=public"

# Object storage (future firmware/files)
STORAGE_PROVIDER="s3"
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Auth
AUTH_SECRET="change-me-with-a-long-random-secret"
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
